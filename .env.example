# Copy to .env in the repo root.

# Required: Base58 merchant address on Nile (receives USDT/TRX)
MERCHANT_TRON_ADDRESS=
# Optional second merchant for marketplace demos
# SECONDARY_MERCHANT_TRON_ADDRESS=
# Optional path to a JSON service catalog (see config/service-catalog.example.json)
# SERVICE_CATALOG_PATH=config/service-catalog.json

PORT=3001
TRON_FULL_HOST=https://nile.trongrid.io
TRONGRID_API_KEY=

# Default: USDT TRC-20 (consumer-grade “commerce” demo). Set TRX for simplest TronLink native transfer.
PAYMENT_ASSET=USDT

# Premium quote — minimal units (USDT has 6 decimals; 1 USDT = 1_000_000)
PRICE_PREMIUM_USDT_UNITS=1000000
PRICE_PREMIUM_TRX_SUN=1000000

# Market depth — cheaper SKU
PRICE_DEPTH_USDT_UNITS=500000
PRICE_DEPTH_TRX_SUN=500000

# Override if your Nile USDT deployment differs
# TRON_NILE_USDT_CONTRACT=

MIN_CONFIRMATIONS=1
ACCESS_TOKEN_TTL_SEC=3600

# Settlement receipt signing keys (PEM). In production, set both.
# RECEIPT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# RECEIPT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# SQLite audit log (relative paths resolve to monorepo root)
# DATABASE_PATH=data/commerce.db

# Optional: comma-separated payer allowlist
# ALLOWED_PAYER_ADDRESSES=

# Autonomous agent script only (`npm run agent:auto`) — payer hex private key, Nile, NEVER commit
# NILE_PAYER_PRIVATE_KEY=

# AI agent (`npm run agent:ai`) — set one or both keys below
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=auto
# OPENAI_MODEL=gpt-4.1-mini
# Set AI_PROVIDER=demo to skip LLM calls and buy the data feeds directly.
# PAYMENT_VERIFY_MAX_RETRIES=18
# PAYMENT_VERIFY_DELAY_MS=5000
# EXPECTED_PAYMENT_SCHEME=tron-settlement
# EXPECTED_SETTLEMENT_NETWORK=tron-nile
# EXPECTED_MERCHANT_ADDRESSES=T...,T...
# AGENT_MAX_USDT_UNITS=2000000
# AGENT_MAX_TRX_SUN=2000000
# AGENT_MIN_TRUST_SCORE=70

# AI agent task override (default: TRX/USDT market analysis)
# TASK=Is now a good time to buy TRX?
